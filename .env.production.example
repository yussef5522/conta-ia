# =============================================================
# Conta IA — Variáveis de Ambiente (PRODUÇÃO)
#
# NÃO commitar este arquivo com valores reais. Cópia limpa:
#   cp .env.production.example .env
# Depois preencha com os valores reais do servidor (ver docs/DEPLOY.md).
# =============================================================

# ---------------------
# Banco de dados — PostgreSQL 16
# ---------------------
# Formato: postgresql://USER:SENHA@HOST:PORTA/DATABASE?schema=public
#
# ⚠️ URL-ENCODING: se a senha contiver caracteres reservados (@ : / # ?),
# substitua-os pelas formas escapadas:
#   @  →  %40
#   :  →  %3A
#   /  →  %2F
#   #  →  %23
#   ?  →  %3F
#   espaço → %20
#
# Exemplo: senha "ContaIA@DB2026" vira "ContaIA%40DB2026" na URL.
DATABASE_URL="postgresql://USER_AQUI:SENHA_URL_ENCODED@localhost:5432/DATABASE_AQUI?schema=public"

# ---------------------
# Autenticação JWT
# ---------------------
# Gere com: openssl rand -base64 64
# Mínimo 64 caracteres aleatórios. Não reutilize a chave do dev.
JWT_SECRET="GERAR_COM_OPENSSL_RAND_BASE64_64"

# ---------------------
# URL pública da aplicação
# ---------------------
# Use HTTP só temporariamente. Configure HTTPS via nginx + Let's Encrypt
# antes de aceitar tráfego de clientes reais.
NEXT_PUBLIC_APP_URL="http://IP_OU_DOMINIO_AQUI"

# ---------------------
# Ambiente Node
# ---------------------
NODE_ENV="production"

# ---------------------
# Cookie Secure flag
# ---------------------
# Por padrão, em produção o cookie de auth é "Secure" (só transmitido em HTTPS).
# Enquanto o servidor ainda estiver em HTTP puro (sem SSL configurado), descomente
# a linha abaixo para permitir que o login funcione. REMOVER após habilitar HTTPS
# (Let's Encrypt + nginx) — caso contrário o cookie fica vulnerável a interceptação.
# COOKIE_SECURE="false"

# ---------------------
# Anthropic (IA Contadora) — FASE 3 (opcional até ativar IA)
# ---------------------
# ANTHROPIC_API_KEY="sk-ant-..."

# ---------------------
# Pluggy (Open Finance) — FASE 10 (adiado, opcional)
# ---------------------
# PLUGGY_CLIENT_ID=""
# PLUGGY_CLIENT_SECRET=""

# ---------------------
# Stripe (Pagamentos SaaS) — FASE 7 (opcional)
# ---------------------
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
