# =============================================================
# Conta IA — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# =============================================================

# ---------------------
# Banco de dados
# ---------------------
# Desenvolvimento: SQLite (arquivo local)
DATABASE_URL="file:./dev.db"

# Produção: PostgreSQL
# DATABASE_URL="postgresql://usuario:senha@host:5432/conta_ia"

# ---------------------
# Autenticação JWT
# ---------------------
# Gere uma string aleatória forte (ex: openssl rand -base64 64)
JWT_SECRET="sua-chave-secreta-muito-longa-e-aleatoria-aqui"

# ---------------------
# URL da aplicação
# ---------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------------------
# Anthropic (IA Contadora) — Fase futura
# ---------------------
# ANTHROPIC_API_KEY="sk-ant-..."

# ---------------------
# Pluggy (Open Finance) — Fase futura
# ---------------------
# PLUGGY_CLIENT_ID=""
# PLUGGY_CLIENT_SECRET=""

# ---------------------
# Stripe (Pagamentos SaaS) — Fase futura
# ---------------------
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
