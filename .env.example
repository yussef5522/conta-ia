# =============================================================
# Conta IA — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# =============================================================

# ---------------------
# Banco de dados
# ---------------------
# O schema Prisma usa PostgreSQL. Para desenvolvimento local, instale
# PostgreSQL 16 localmente (ou via Docker) e ajuste as credenciais abaixo.
#
# Desenvolvimento local:
DATABASE_URL="postgresql://contaia_user:SENHA_AQUI@localhost:5432/contaia_dev"
#
# Produção (DigitalOcean):
# DATABASE_URL="postgresql://contaia_user:SENHA_FORTE_AQUI@localhost:5432/contaia_production"

# ---------------------
# Autenticação JWT
# ---------------------
# Gere com: openssl rand -base64 64
JWT_SECRET="sua-chave-secreta-muito-longa-e-aleatoria-aqui"

# ---------------------
# URL da aplicação
# ---------------------
# Desenvolvimento:
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Produção:
# NEXT_PUBLIC_APP_URL="http://167.172.159.XXX"

# ---------------------
# Anthropic (IA Contadora) — FASE 3
# ---------------------
# ANTHROPIC_API_KEY="sk-ant-..."

# ---------------------
# Pluggy (Open Finance) — FASE 8 (adiado)
# ---------------------
# PLUGGY_CLIENT_ID=""
# PLUGGY_CLIENT_SECRET=""

# ---------------------
# Stripe (Pagamentos SaaS) — FASE 7
# ---------------------
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
