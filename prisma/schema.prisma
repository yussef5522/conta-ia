generator client {
  provider = "prisma-client-js"
}

datasource db {
  // dev: sqlite — produção: postgresql (ver docs/DEPLOY.md etapa 5)
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(cuid())
  name     String
  email    String @unique
  password String
  role     String @default("CLIENT")

  // Sprint 4.0.4 — preferências de email alerts.
  // Default false (opt-in seguro): user ativa em /configuracoes/alertas.
  // Frequência DAILY = cron 8:00 dias úteis; WEEKLY = segunda 8:00; NONE = não envia.
  emailAlertsEnabled   Boolean @default(false)
  emailAlertsFrequency String  @default("DAILY")

  // Sprint Gestão de Conta (31/05/2026) — quando admin reseta a senha
  // do cliente, seta true → próximo login redireciona pra /trocar-senha
  // antes do dashboard. Zera após user definir nova senha.
  mustChangePassword Boolean @default(false)

  // Sprint Asaas 3B (31/05/2026) — CPF (11 dígitos) ou CNPJ (14).
  // SÓ dígitos. Coletado no checkout 1ª vez. Não-unique pois cônjuges
  // ou MEI+PF do mesmo CPF podem ter contas separadas.
  cpfCnpj String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscription Subscription?

  companies                  UserCompany[]
  categoryHistory            CategoryHistory[]
  categoryRestoreLogs        CategoryRestoreLog[]
  userCompanyRoles           UserCompanyRole[]
  auditLogs                  AuditLog[]
  sentInvites                CompanyInvite[]           @relation("InvitedBy")
  // Fase 3 Etapa 3 — Camada 3 do pipeline IA Contadora
  aiUsageLogs                AiUsageLog[]
  // Sprint 5.0.4.0c1 — Insights narrativos Sonnet 4.6
  aiInsightsLogs             AiInsightsLog[]
  // Sprint 1.5 — Esqueci senha (código 6 dígitos via Resend)
  passwordResetCodes         PasswordResetCode[]
  // Sprint 1.7 — Cupons aplicados no signup
  couponRedemptions          CouponRedemption[]
  // Onda 2 Sprint 2.3 — quem importou cada OFX
  ofxImports                 OfxImport[]
  ofxImportsReverted         OfxImport[]               @relation("OfxImportReverter")
  // Sprint A-effected Fase B — quem ignorou cada tx (Transaction.ignoredBy)
  transactionsIgnored        Transaction[]             @relation("TransactionIgnoredBy")
  // Sprint PF Fatia 3
  personalOfxImports         PersonalOfxImport[]
  personalOfxImportsReverted PersonalOfxImport[]       @relation("PersonalOfxImportReverter")
  // Sprint PF Fatia 3.5
  pdfExtractCaches           PersonalPdfExtractCache[] @relation("PdfCacheOwner")
  // Sprint 4.0.1.b — quem criou cada schedule recorrente
  recurringSchedules         RecurringSchedule[]
  // Sprint 5.0.1 — IA Tributária
  createdTaxProfiles         CompanyTaxProfile[]       @relation("TaxProfileCreator")
  // Sprint 5.0.3.0c — Saved views customizadas (CRUD em /contas-a-pagar)
  savedViews                 SavedView[]

  // Sprint PF Fatia 1 (02/06/2026) — Perfis pessoa física.
  personalProfiles UserPersonalProfile[]

  // Sprint PF Fatia 1 (02/06/2026) — Onboarding (pergunta PF/PJ).
  // null = users existentes (legacy) — pulam o onboarding.
  // Setado quando user completa o /onboarding.
  onboardingCompletedAt DateTime?

  // Sprint PF Fatia 4 (03/06/2026) — Pontes criadas por este user.
  pjToPfBridges PJtoPFBridge[]

  @@map("users")
}

// Sprint 5.0.3.0c ELITE — Views customizadas (tabs em /contas-a-pagar etc).
// As 4 views default (Todas/Vencidas/A vencer 7d/Pagas no mês) continuam
// hardcoded em lib/contas-pagar/saved-views.ts. Esta tabela armazena APENAS
// views CUSTOM criadas pelo usuário.
//
// Multi-tenant: usuário só vê SUAS próprias views (não as de outros usuários
// da mesma empresa).
model SavedView {
  id           String   @id @default(cuid())
  userId       String
  empresaId    String? // null = view global do usuário (todas empresas)
  scope        String   @default("payable") // payable | receivable | transactions
  name         String
  icon         String? // emoji curto (1-4 chars)
  filters      String // JSON com filtros aplicados
  sortBy       String?
  sortDir      String? // asc | desc
  columnOrder  String   @default("[]") // JSON array
  columnHidden String   @default("[]") // JSON array
  density      String   @default("normal") // compact | normal | comfortable
  pinnedOrder  Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, empresaId, scope, name])
  @@index([userId, empresaId, scope])
  @@map("saved_views")
}

model Company {
  id        String  @id @default(cuid())
  cnpj      String  @unique
  name      String
  tradeName String?
  type      String  @default("OTHER")
  // Sprint 5.0.2.l — Setor normalizado pra Knowledge Base setorial.
  // Valores: RESTAURANTE | ACADEMIA | COMERCIO_ROUPA | VAREJO_GERAL | OTHER.
  // null permitido pra empresas legado (categorização cai só nas regras UNIVERSAL).
  setor     String?
  email     String?
  phone     String?
  address   String?
  city      String?
  state     String?
  zipCode   String?
  taxRegime String  @default("SIMPLES_NACIONAL")
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                UserCompany[]
  bankAccounts         BankAccount[]
  categories           Category[]
  suppliers            Supplier[]
  customers            Customer[]
  recurringSchedules   RecurringSchedule[]
  rules                AiLearningRule[]
  costCenters          CostCenter[]
  categoryHistory      CategoryHistory[]
  restoreLogs          CategoryRestoreLog[]
  roles                Role[]
  userCompanyRoles     UserCompanyRole[]
  auditLogs            AuditLog[]
  invites              CompanyInvite[]
  // Fase 3 Etapa 3 — Camada 3 do pipeline IA Contadora
  aiClaudeCache        AiClaudeCache[]
  aiUsageLogs          AiUsageLog[]
  // Sprint 5.0.4.0c1 — Insights narrativos Sonnet 4.6
  aiInsightsLogs       AiInsightsLog[]
  // Sprint 5.0.1 — IA Tributária
  taxProfile           CompanyTaxProfile?
  taxCalculations      TaxCalculation[]
  // Sprint 5.0.2.d — Claude analyzing real
  aiAnalysisCache      AiAnalysisCache[]
  // Sprint 5.0.2.h — Detecção Pix PJ↔PF/PJ
  sociosPF             SocioPF[]
  empresasRelacionadas EmpresaRelacionada[]
  // Sprint 5.0.2.u — Multi-statement staging (Xero/QuickBooks pattern)
  importStagings       ImportStaging[]
  // Sprint 5.0.2.0 — Importador Excel Contas a Pagar
  employees            Employee[]
  excelImportBatches   ExcelImportBatch[]
  // Sprint PF Fatia 4 (03/06/2026) — Pontes desta empresa
  pjToPfBridges        PJtoPFBridge[]

  @@map("companies")
}

model UserCompany {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  role      String   @default("OWNER")
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@map("user_companies")
}

model BankAccount {
  id            String  @id @default(cuid())
  companyId     String
  name          String
  bankName      String?
  bankCode      String?
  agency        String?
  accountNumber String?
  accountType   String  @default("CHECKING")
  balance       Float   @default(0)

  // Saldo negativo / cheque especial (Sprint 0.5).
  // allowNegativeBalance: se false, lançamentos/transferências que deixariam
  //   saldo < -creditLimit são bloqueados na app-layer.
  // creditLimit: limite do cheque especial em reais (positivo). Saldo mínimo
  //   permitido = -creditLimit.
  // lowBalanceThreshold: valor abaixo do qual a IA dispara alerta proativo.
  //   null = sem alerta configurado.
  allowNegativeBalance Boolean @default(true)
  creditLimit          Float   @default(0)
  lowBalanceThreshold  Float?

  pluggyItemId    String?
  pluggyAccountId String?
  isActive        Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  transactions   Transaction[]
  // Onda 2 Sprint 2.3 — histórico de imports OFX
  ofxImports     OfxImport[]
  // Sprint 5.0.2.u — multi-statement staging
  importStagings ImportStaging[]

  @@map("bank_accounts")
}

model Transaction {
  id            String   @id @default(cuid())
  // Sprint 4.0.1.a — bankAccountId nullable pra PAYABLE/RECEIVABLE criados sem
  // conta definida (user nem sabe ainda de qual conta vai pagar a luz).
  // Setado na efetivação manual OU conciliação OFX.
  bankAccountId String?
  categoryId    String?
  date          DateTime
  description   String
  amount        Float
  // CREDIT = entrada de dinheiro, DEBIT = saída, TRANSFER = par de transferência interna (Sprint 0.5)
  type          String
  // PENDING | RECONCILED | IGNORED
  status        String   @default("PENDING")
  // MANUAL | OFX | PLUGGY
  origin        String   @default("MANUAL")
  // ID original da transação na fonte (OFX FITID ou Pluggy ID) — preservado para auditoria.
  // Não é mais usado como chave de deduplicação porque alguns bancos (ex: Banrisul) reusam
  // FITIDs entre transações distintas. Ver lib/ofx/dedup.ts.
  externalId    String?
  // Chave interna de deduplicação. Para OFX é sha256(fitid + data + valor + memo).
  // Pluggy ainda não preenche este campo (NULLs não conflitam com a unique).
  dedupHash     String?

  // Transferência entre contas DA MESMA empresa (Sprint 0.5).
  // Quando preenchido, é o ID que une as 2 pontas (saída na conta A + entrada na conta B).
  // Ambas as transações pareadas têm type = "TRANSFER" e o MESMO transferGroupId.
  // Filtrado em DRE e Fluxo Consolidado (não infla receita/despesa).
  // Mantido em Fluxo POR CONTA (mostra entrada/saída normalmente).
  transferGroupId String?

  // Sprint Central de Transferências (Detecção Retroativa) — marcado quando
  // user clica "Não é transferência" num par sugerido pela varredura. A
  // varredura filtra IS NULL pra não voltar a sugerir o mesmo par. Reversível
  // via UPDATE direta no DB ou tela administrativa (futuro).
  transferDismissedAt DateTime?

  notes String?

  // Classificação automática (FASE 3+4 — IA Contadora)
  // Fornecedor identificado (via regra CNPJ ou lookup BrasilAPI)
  supplierId           String?
  // Sprint 5.0.2.0 — Funcionário relacionado (alternativo a supplierId pra
  // PAYABLE de folha). Mutuamente exclusivo com supplierId na prática.
  employeeId           String?
  // Qual regra aplicou a categoria (NULL quando classificação foi manual ou veio de outra fonte)
  classifiedByRuleId   String?
  // Confiança no momento da classificação (snapshot, pode divergir de rule.confianca atual)
  aiConfidence         Float?
  // MANUAL | RULE | BRASILAPI | AI — origem da classificação
  classificationSource String?

  // Regime competência (CFC) — Sub-etapa 5.3.A.
  // competenceDate: data do fato gerador (quando o serviço/produto foi prestado/adquirido).
  // paymentDate: data efetiva do pagamento (caixa). Pode ser null se ainda não foi pago.
  // Em backfill, competenceDate = date (transactionDate) por padrão conservador.
  competenceDate DateTime?
  paymentDate    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Centro de custo (matriz/filial/unidade) — útil pra DRE consolidado de
  // grupos com várias empresas/filiais. Independente da categoria/DRE group.
  costCenterId String?

  // Onda 2 Sprint 2.3 — qual import OFX trouxe essa transação (null = manual / antes da Onda 2).
  importId String?

  // Sprint 5.0.2.h — Detecção Pix relacionado.
  // relatedPartyType: SOCIO_PF | GRUPO_PJ | null
  // relatedPartyId: aponta pra SocioPF.id ou EmpresaRelacionada.id (não FK
  //   constrained — flexibilidade pra detecção retroativa sem cascade).
  relatedPartyType String?
  relatedPartyId   String?

  // Sprint 5.0.2.i — Conciliação automática Transferência interna grupo.
  // Quando match entre Empresa A (saída) ↔ Empresa B (entrada) confirmado,
  // ambas marcadas isInternalTransfer=true e linkadas pelo linkedTransactionId.
  // DRE e fluxo CONSOLIDADO filtram isInternalTransfer=true.
  isInternalTransfer  Boolean @default(false)
  linkedTransactionId String? @unique

  // Sprint 4.0.1.a — Core Financeiro AP/AR.
  // lifecycle distingue lançamento REAL (EFFECTED — extrato OFX ou pagamento manual já feito)
  // de lançamento PENDENTE (PAYABLE = conta a pagar, RECEIVABLE = conta a receber).
  // DRE filtra lifecycle='EFFECTED' (visão Realizado) ou inclui PAYABLE/RECEIVABLE (visão Previsto).
  lifecycle        String        @default("EFFECTED")
  // dueDate é a data esperada de pagamento/recebimento (só faz sentido em PAYABLE/RECEIVABLE).
  // Quando vira EFFECTED via efetivação manual ou conciliação OFX, paymentDate é setado e
  // a data principal (`date`) reflete o caixa real.
  dueDate          DateTime?
  // Quando uma PAYABLE/RECEIVABLE é conciliada com uma tx OFX, aponta pra ela.
  // Estratégia "link" (não merge): preserva FITID/dedupHash/importId pra auditoria fiscal +
  // permite desfazer conciliação. DRE caixa filtra `reconciledWithId IS NULL` pra evitar dupla contagem.
  // Sprint A-effected Fase B.3: @unique REMOVIDO pra suportar N:1 (várias APs
  // apontando pra mesma OFX — caso CIA DA FRUTA). Defesa em profundidade
  // continua via: 3 camadas de guards reconciledFrom + validação de soma
  // exata (±0.01) no endpoint find-and-match/reconcile + flag
  // allowMultiReconcile no lib/conciliacao/reconcile.
  reconciledWithId String?
  reconciledWith   Transaction?  @relation("ConciliationLink", fields: [reconciledWithId], references: [id])
  reconciledFrom   Transaction[] @relation("ConciliationLink")
  // Sprint A-effected Fase B.3: agrupa N:1 (várias candidates conciliadas
  // com mesma OFX via Find & Match). null = single 1:1 ou pré-B.3.
  reconcileGroupId String?

  // RECEIVABLE pode vincular cliente (Customer); PAYABLE usa supplierId já existente.
  customerId String?

  // Sprint 4.0.1.b — gerada por schedule recorrente. Null = lançamento manual ou OFX.
  // Anti-duplicação via @@unique([recurringScheduleId, dueDate]) abaixo: garante
  // que o job de geração diária NÃO crie 2 tx pra mesma data se rodar 2x.
  recurringScheduleId String?
  recurringSchedule   RecurringSchedule? @relation(fields: [recurringScheduleId], references: [id], onDelete: SetNull)

  bankAccount      BankAccount?    @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  category         Category?       @relation(fields: [categoryId], references: [id])
  supplier         Supplier?       @relation(fields: [supplierId], references: [id])
  customer         Customer?       @relation(fields: [customerId], references: [id])
  // Sprint 5.0.2.0 — Funcionário (folha de pagamento via import Excel)
  employee         Employee?       @relation(fields: [employeeId], references: [id])
  classifiedByRule AiLearningRule? @relation(fields: [classifiedByRuleId], references: [id])
  costCenter       CostCenter?     @relation(fields: [costCenterId], references: [id])
  // Onda 2 Sprint 2.3 — vínculo com OfxImport (SetNull se import for deletado)
  ofxImport        OfxImport?      @relation(fields: [importId], references: [id], onDelete: SetNull)
  // Sprint PF Fatia 4 (03/06/2026) — Ponte PJ→PF (1:0..1).
  // Restrict no delete: pra deletar essa tx PJ, remover a ponte antes.
  bridge           PJtoPFBridge?   @relation("PjBridge")

  // Sprint A-effected Fase B (03/06/2026) — Ações IGNORAR + CRIAR (cash coding).
  // IGNORAR marca tx como não-conciliável (taxa banco, estorno, lançamento errado).
  // Lista de pendentes filtra ignoredAt IS NULL.
  ignoredAt       DateTime?
  ignoredReason   String?
  ignoredByUserId String?
  ignoredBy       User?     @relation("TransactionIgnoredBy", fields: [ignoredByUserId], references: [id])
  // CRIAR (cash coding estilo Xero): categorizada direto sem candidato AP.
  // Diferencia de "EFFECTED conciliada via match" pra relatórios futuros.
  cashCoded       Boolean   @default(false)
  cashCodedAt     DateTime?

  @@unique([bankAccountId, dedupHash])
  // Sprint 4.0.1.b — anti-dup: schedule X só gera 1 tx por dueDate
  @@unique([recurringScheduleId, dueDate])
  @@index([bankAccountId, externalId])
  @@index([bankAccountId, date])
  @@index([costCenterId])
  @@index([transferGroupId])
  @@index([importId])
  @@index([lifecycle, dueDate])
  @@index([lifecycle, status])
  @@index([customerId])
  @@index([recurringScheduleId])
  @@index([relatedPartyType])
  @@index([isInternalTransfer])
  // Sprint A-effected Fase B.3: índice não-único em reconciledWithId
  // (substitui o @unique removido pra permitir N:1) + reconcileGroupId
  // pra lookups rápidos de undo do grupo.
  @@index([reconciledWithId])
  @@index([reconcileGroupId])
  @@map("transactions")
}

// Plano de Contas — modelo profissional inspirado em Conta Azul / QuickBooks /
// Plano de Contas Referencial SPED. Suporta hierarquia em árvore (até 3 níveis,
// validado app-layer), grupo do DRE Gerencial e código contábil.
model Category {
  id               String  @id @default(cuid())
  companyId        String
  name             String
  // INCOME | EXPENSE | TRANSFER (mantido pra compat — DRE group dá granularidade)
  type             String
  color            String  @default("#6366f1")
  icon             String?
  // Hierarquia em árvore: parent é null para categorias-raiz.
  parentId         String?
  // Grupo do DRE Gerencial (ver lib/dre-groups/). Define onde a categoria
  // aparece no relatório DRE: RECEITA_BRUTA, DEDUCOES, CUSTO_PRODUTO_VENDIDO,
  // DESPESAS_COMERCIAIS, DESPESAS_ADMINISTRATIVAS, DESPESAS_PESSOAL,
  // RECEITAS_FINANCEIRAS, DESPESAS_FINANCEIRAS, OUTRAS_RECEITAS, OUTRAS_DESPESAS,
  // IMPOSTOS_SOBRE_LUCRO, DISTRIBUICAO_LUCROS, INVESTIMENTOS, TRANSFERENCIA.
  dreGroup         String?
  // Código contábil opcional, padrão SPED (ex: "1.01.001"). Único por empresa
  // quando preenchido (validado app-layer).
  code             String?
  // Texto explicativo opcional (quando usar, exemplos).
  description      String?
  // Categoria criada pelo template do sistema. Não pode ser hard-deletada;
  // type e dreGroup ficam protegidos contra edição. Renomeada de `isDefault`
  // (semântica antiga era ambígua).
  isSystemDefault  Boolean @default(false)
  isActive         Boolean @default(true)
  // Ordenação manual. Float pra suportar drag-and-drop (insere entre dois itens
  // sem reordenar a lista inteira). Default 0; valor real é calculado app-layer
  // ao criar (max(order) + 1) ou ao reordenar.
  order            Float   @default(0)
  // Multi-regime tributário: JSON array de regimes onde a categoria fica visível.
  // null = visível em todos os regimes (default).
  // Exemplo: '["LUCRO_PRESUMIDO","LUCRO_REAL"]' pra ISS, IRPJ, CSLL.
  // Filtragem é app-layer (lib/categories/regimes.ts:categoriaVisivelNoRegime).
  visibleInRegimes String?
  // Chave lógica do template (Sub-etapa 5.1.E). Preenchida em isSystemDefault=true
  // via backfill em scripts/backfill-template-keys.ts. Permite identificar
  // categorias do template após edições do usuário (nome muda, templateKey não).
  // Formato: "SETOR:DRE_GROUP:slug_do_nome_original" (ver lib/categories/template-key.ts).
  // null em categorias custom (isSystemDefault=false).
  templateKey      String?

  // Sprint 5.0.2.s — Categoria gera CRÉDITO de PIS/COFINS no Lucro Real
  // (insumo, embalagem, energia, gás, transporte de mercadoria).
  // Para Simples/Lucro Presumido fica ignorado.
  // Default false: regra contábil exige declaração explícita.
  isCreditavel Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent             Category?           @relation("CategoryParent", fields: [parentId], references: [id], onDelete: SetNull)
  children           Category[]          @relation("CategoryParent")
  transactions       Transaction[]
  suppliers          Supplier[]
  customers          Customer[]
  recurringSchedules RecurringSchedule[]
  rules              AiLearningRule[]
  history            CategoryHistory[]

  // Mesma sub-categoria pode existir em parents diferentes (ex: "Outras"
  // sob "Receita Operacional" e sob "Despesas Operacionais").
  @@unique([companyId, parentId, name])
  @@index([companyId, parentId, order])
  @@index([companyId, dreGroup])
  @@index([templateKey])
  @@map("categories")
}

// Centro de custo — agrupador transversal independente das categorias.
// Permite consolidar DRE por unidade (ex: "Academia Centro" vs "Academia Sul")
// sem afetar a estrutura do plano de contas.
//
// Hierarquia em árvore (matriz → filiais), validada app-layer.
model CostCenter {
  id          String  @id @default(cuid())
  companyId   String
  name        String
  // Código do centro de custo (ex: "001-MATRIZ", "002-FILIAL-CENTRO")
  code        String?
  description String?
  parentId    String?
  isActive    Boolean @default(true)
  order       Float   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent       CostCenter?   @relation("CostCenterParent", fields: [parentId], references: [id], onDelete: SetNull)
  children     CostCenter[]  @relation("CostCenterParent")
  transactions Transaction[]

  @@unique([companyId, parentId, name])
  @@index([companyId, parentId, order])
  @@index([companyId, isActive])
  @@map("cost_centers")
}

// Audit log de mudanças em Category. Registra ações pra rastreabilidade
// contábil ("por que essa categoria mudou em outubro?") e compliance LGPD.
// changedFields é JSON com { campo: { before, after } } pra ações UPDATE.
model CategoryHistory {
  id            String   @id @default(cuid())
  categoryId    String
  companyId     String
  // userId é nullable: NULL quando a ação foi feita pelo sistema (seed,
  // backfill, aplicar template).
  userId        String?
  // CREATE | UPDATE | SOFT_DELETE | RESTORE | RENAME | APPLY_TEMPLATE
  action        String
  // JSON serializado: { campo: { before, after } } para UPDATEs.
  changedFields String?
  createdAt     DateTime @default(now())

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId, categoryId, createdAt])
  @@index([userId, createdAt])
  @@map("category_history")
}

// Fornecedores identificados em transações (manualmente ou via BrasilAPI lookup por CNPJ).
// Usado pra agrupar transações, sugerir categoria e dar visibilidade na tela "Fornecedores" (4.8).
// Multi-tenant: cada empresa tem sua própria base; mesmo CNPJ pode existir em duas empresas distintas.
// Sprint 4.0.1.a — Customer (cliente). Espelha Supplier mas semanticamente
// é a contraparte de RECEIVABLE (quem nos PAGA). Cadastro pode ser:
//   - MANUAL (Yussef criou)
//   - BRASILAPI (lookup público quando CNPJ identificado em descrição)
// Multi-tenant: cada empresa tem seus customers (Cacula Mix ≠ Academia X).
model Customer {
  id                String    @id @default(cuid())
  companyId         String
  cnpj              String?
  cpf               String?
  razaoSocial       String
  nomeFantasia      String?
  email             String?
  phone             String?
  // Categoria padrão sugerida (geralmente uma RECEITA_BRUTA específica)
  categoryId        String?
  fonte             String    @default("MANUAL")
  fonteAtualizadaEm DateTime?
  isActive          Boolean   @default(true)
  notes             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category           Category?           @relation(fields: [categoryId], references: [id])
  transactions       Transaction[]
  recurringSchedules RecurringSchedule[]

  // Mesmo CNPJ pode existir em duas empresas-tenant diferentes
  @@unique([companyId, cnpj])
  @@index([companyId, razaoSocial])
  @@index([companyId, isActive])
  @@map("customers")
}

model Supplier {
  id                String    @id @default(cuid())
  companyId         String
  cnpj              String?
  razaoSocial       String
  nomeFantasia      String?
  // Categoria padrão sugerida; nullable porque BrasilAPI pode trazer CNAE sem categoria correspondente
  categoryId        String?
  // CNAE primário (vindo da BrasilAPI), útil pra heurística de categoria
  cnaePrincipal     String?
  // MANUAL = cadastrado pelo Yussef; BRASILAPI = lookup público da Receita
  fonte             String    @default("MANUAL")
  // Quando o lookup BrasilAPI rodou (pra refresh futuro)
  fonteAtualizadaEm DateTime?
  isActive          Boolean   @default(true)
  notes             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category           Category?           @relation(fields: [categoryId], references: [id])
  transactions       Transaction[]
  rules              AiLearningRule[]
  recurringSchedules RecurringSchedule[]

  // Mesmo CNPJ pode existir em duas empresas-cliente diferentes
  @@unique([companyId, cnpj])
  @@index([companyId, razaoSocial])
  @@index([companyId, isActive])
  @@map("suppliers")
}

// Regras de classificação automática aprendidas a partir das confirmações manuais do usuário.
// Pipeline (4.2 → 4.3 → 4.4): match em rules → CNPJ via BrasilAPI → Claude Haiku.
// Multi-tenant: regras NÃO são compartilhadas entre empresas (academia ≠ restaurante).
// Sprint 4.0.1.b — Recurrence (recorrentes).
// Modela compromissos repetitivos (folha mensal, aluguel, mensalidade).
// Job diário (lib/recurrence/scheduler.ts via node-cron 06:00 America/Sao_Paulo)
// gera Transaction PENDING (lifecycle PAYABLE ou RECEIVABLE) na janela dos próximos
// 7 dias. Anti-dup via @@unique([recurringScheduleId, dueDate]) em transactions.
model RecurringSchedule {
  id        String @id @default(cuid())
  companyId String

  // Identificação
  description String
  // Tipo: PAYABLE (a pagar) ou RECEIVABLE (a receber).
  // Espelha o lifecycle que cada Transaction gerada terá.
  type        String

  // Valor fixo. Quando o usuário cria conta com valor variável (água/luz),
  // ele edita a Transaction depois da geração.
  amount Float

  // Periodicidade.
  //   MONTHLY    — uma vez por mês, dia `dayOfMonth`
  //   WEEKLY     — uma vez por semana, dia `dayOfWeek` (0=domingo, 6=sábado)
  //   QUARTERLY  — uma vez a cada 3 meses, dia `dayOfMonth` (mês = startDate.month + 3n)
  //   YEARLY     — uma vez por ano, dia `dayOfMonth` no mesmo mês de startDate
  frequency  String
  dayOfMonth Int?
  dayOfWeek  Int?

  // Vigência: gera apenas se hoje >= startDate. Para se hoje > endDate (null = sem fim).
  startDate DateTime
  endDate   DateTime?

  // Estado: false = pausado, NÃO gera novas tx (mas as já geradas continuam).
  active Boolean @default(true)

  // Última data em que o job rodou pra esse schedule (UTC). Audit/telemetria.
  lastGeneratedAt DateTime?

  // FKs opcionais (mesma regra de PAYABLE/RECEIVABLE manual)
  supplierId String?
  customerId String?
  categoryId String?
  notes      String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplier     Supplier?     @relation(fields: [supplierId], references: [id])
  customer     Customer?     @relation(fields: [customerId], references: [id])
  category     Category?     @relation(fields: [categoryId], references: [id])
  createdBy    User          @relation(fields: [createdById], references: [id])
  transactions Transaction[]

  @@index([companyId, active])
  @@index([type, frequency])
  @@map("recurring_schedules")
}

model AiLearningRule {
  id                 String  @id @default(cuid())
  // Sprint PF Fatia 3 — companyId virou nullable.
  // Quando regra é PJ → companyId preenchido, profileId null.
  // Quando regra é PF → profileId preenchido, companyId null.
  // Mutuamente exclusivo (validado em app-layer).
  companyId          String?
  profileId          String?
  // EXACT = description igual a `padrao`
  // CONTAINS = description contém `padrao` (case-insensitive)
  // CNPJ = description contém o CNPJ em `padrao`
  tipoMatch          String
  padrao             String
  categoryId         String?
  personalCategoryId String?
  supplierId         String?
  // Intrínseca da regra: 1.0 = manual; <1 = sugerida por Claude
  confianca          Float   @default(1.0)
  // Telemetria pra ranking / faxina futura
  vezesAplicada      Int     @default(0)
  isActive           Boolean @default(true)
  // MANUAL = Yussef criou; CLAUDE = sugerida automaticamente
  fonte              String  @default("MANUAL")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company              Company?              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  profile              PersonalProfile?      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  category             Category?             @relation(fields: [categoryId], references: [id])
  personalCategory     PersonalCategory?     @relation(fields: [personalCategoryId], references: [id])
  supplier             Supplier?             @relation(fields: [supplierId], references: [id])
  transactions         Transaction[]
  personalTransactions PersonalTransaction[] @relation("PfClassifiedByRule")

  // Não pode haver duas regras com mesmo padrão e tipo na mesma empresa
  @@unique([companyId, tipoMatch, padrao])
  @@unique([profileId, tipoMatch, padrao])
  // Lookup rápido durante import
  @@index([companyId, isActive, tipoMatch])
  @@index([profileId, isActive, tipoMatch])
  @@map("ai_learning_rules")
}

// Permissões canônicas do sistema (Sub-etapa 5.3.A).
// Lista fechada gerenciada em código (lib/auth/permissions.ts) e sincronizada
// via scripts/seed-rbac.ts (idempotente). UI consulta esta tabela pra exibir
// catálogo agrupado, mas a fonte da verdade são as constantes em código.
model Permission {
  id          String  @id @default(cuid())
  // "category.create", "transaction.view", "company.delete", etc.
  key         String  @unique
  // Rótulo amigável: "Criar categoria"
  name        String
  // Descrição opcional pra hint na UI
  description String?
  // Agrupador na UI: "Categorias", "Transações", "Empresa", "Usuários", etc.
  group       String

  rolePermissions RolePermission[]

  @@index([group])
  @@map("permissions")
}

// Roles do sistema RBAC (Sub-etapa 5.3.A).
// - Roles padrão: companyId = null + isSystemDefault = true (globais, imutáveis).
// - Roles custom: companyId preenchido + isSystemDefault = false (escopadas por empresa).
model Role {
  id              String   @id @default(cuid())
  // OWNER, ADMIN, ACCOUNTANT, FINANCIAL, VIEWER (padrão) ou nome custom escolhido pelo user
  name            String
  description     String?
  // true bloqueia edição (UI não permite mexer)
  isSystemDefault Boolean  @default(false)
  // null = role global (padrão); preenchido = role custom da empresa
  companyId       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company          Company?          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  permissions      RolePermission[]
  userCompanyRoles UserCompanyRole[]
  invites          CompanyInvite[]

  // Nome único por empresa (custom). Pra roles globais (companyId=null), garante
  // que só haja UM "OWNER", UM "ADMIN", etc. globalmente.
  @@unique([companyId, name])
  @@index([companyId])
  @@index([isSystemDefault])
  @@map("roles")
}

// Many-to-many entre Role e Permission (Sub-etapa 5.3.A).
// Tabela de junção pura. Sincronizada pelo seed pra roles padrão.
// Roles custom têm permissões editadas pelo OWNER/ADMIN da empresa.
model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

// Atribuição de Role a um par (User, Company) (Sub-etapa 5.3.A).
// Substitui o campo `role` simples em UserCompany (que vira obsoleto, mas é
// mantido na 5.3.A pra não quebrar rotas atuais — removido na 5.3.B).
// 1 role por user por empresa.
model UserCompanyRole {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  roleId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  // Restrict: não permite excluir Role que tem UserCompanyRole apontando.
  // Forçar reassign antes de excluir role.
  role    Role    @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([userId])
  @@map("user_company_roles")
}

// Audit log genérico nível de campo (Sub-etapa 5.3.A).
// Substitui o CategoryHistory específico (que continua existindo pra compat,
// mas novas integrações usam este modelo genérico).
//
// Snapshot de userName/userEmail é resiliente: mesmo se o user for deletado
// (userId vira null via SetNull), o histórico preserva quem fez a ação.
model AuditLog {
  id            String   @id @default(cuid())
  companyId     String
  // FK pra User com SetNull on delete (preserva log mesmo se user sumir)
  userId        String?
  // Snapshot do user no momento da ação — resiliente a delete posterior
  userName      String
  userEmail     String
  // CREATE | UPDATE | DELETE | ACTIVATE | DEACTIVATE | RESTORE_TEMPLATE | LOGIN | etc.
  action        String
  // Category | Transaction | Company | BankAccount | Role | UserCompanyRole | etc.
  entityType    String
  entityId      String
  // JSON: { campo: { before: X, after: Y } } pra UPDATE; null pra CREATE/DELETE
  fieldsChanged String?
  // JSON livre: contexto adicional (parentName, valor formatado, etc.)
  metadata      String?
  // Contexto de auditoria/forense
  ipAddress     String?
  userAgent     String?
  timestamp     DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId, timestamp(sort: Desc)])
  @@index([entityType, entityId])
  @@index([userId])
  @@index([action])
  @@map("audit_log")
}

// Convite por link pra empresa (Sub-sub-etapa 5.3.C3).
// Token aleatório de 32 bytes (64 chars hex), expira em 7 dias.
// Email do convite precisa bater com email da conta no momento de aceitar.
// acceptedAt null = pendente; preenchido = aceito (não pode ser cancelado).
model CompanyInvite {
  id          String    @id @default(cuid())
  companyId   String
  // Email do convidado (case-insensitive — sempre lowercase no banco)
  email       String
  // Role que o convidado terá ao aceitar
  roleId      String
  // Token único pro link público
  token       String    @unique
  // Quando o convite expira (now + 7 dias)
  expiresAt   DateTime
  // null = pendente; data preenchida = aceito (snapshot pra audit)
  acceptedAt  DateTime?
  // Quem convidou (resiliente: cascade ao deletar user — ver Restrict em roleId pra evitar perda de role)
  invitedById String
  createdAt   DateTime  @default(now())

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  // Restrict: não permite excluir Role com convites apontando.
  role      Role    @relation(fields: [roleId], references: [id], onDelete: Restrict)
  invitedBy User    @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([token])
  @@index([email, companyId])
  @@map("company_invites")
}

// Audit log de operações "Restaurar Padrão" (Sub-etapa 5.1.E).
// Registra cada vez que o usuário aplica um diff template→atual, com snapshot
// do que mudou. Permanente — não pode ser desfeito automaticamente, mas
// histórico fica pra revisão e troubleshooting.
model CategoryRestoreLog {
  id            String   @id @default(cuid())
  companyId     String
  userId        String
  timestamp     DateTime @default(now())
  // Counts agregados pra exibição rápida no histórico
  revertedCount Int      @default(0)
  removedCount  Int      @default(0)
  addedCount    Int      @default(0)
  // JSON com snapshot do diff aplicado (categorias afetadas, valores antes/depois)
  details       String

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([companyId, timestamp])
  @@map("category_restore_log")
}

// ============================================================
// Fase 3 Etapa 3 — Camada 3 do Pipeline IA Contadora
// ============================================================

// Cache de sugestões geradas pelo Claude API. Evita repetir chamadas pra
// descrições normalizadas iguais (mesma keyword ⇒ mesma sugestão).
// TTL controlado em código (90 dias). Schema dual SQLite/Postgres: usa String
// (não Json) pra portabilidade dual-DB.
model AiClaudeCache {
  id            String   @id @default(cuid())
  companyId     String
  // sha256(normalizeDescription) — determinístico
  cacheKey      String
  // Descrição original — debug/auditoria
  description   String
  // normalizeDescription() — humanamente inspecionável
  normalizedKey String
  // JSON: { categoryId, confidence, reasoning, alternativeCategoryIds }
  suggestion    String
  usageCount    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, cacheKey])
  @@index([companyId, createdAt])
  @@map("ai_claude_cache")
}

// Log de uso da API Claude — pra rate limiting (window por empresa)
// + telemetria de custo + auditoria.
// claudeApiCalled=false significa cache hit (sem custo).
model AiUsageLog {
  id              String   @id @default(cuid())
  companyId       String
  userId          String?
  // Tx que originou a sugestão — rastreabilidade
  transactionId   String?
  claudeApiCalled Boolean  @default(true)
  inputTokens     Int      @default(0)
  outputTokens    Int      @default(0)
  // Custo em centavos USD × 100 (fração centavo armazenada como float-like)
  costCents       Int      @default(0)
  cacheHit        Boolean  @default(false)
  createdAt       DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([companyId, claudeApiCalled, createdAt])
  @@map("ai_usage_log")
}

// Sprint 5.0.4.0c1 — Log de insights narrativos gerados por Sonnet 4.6.
// SEPARADO do AiUsageLog (que é pra ai-categorizer / Haiku) por causa:
// - Modelo diferente (Sonnet vs Haiku) → pricing diferente
// - Feature diferente (insights vs classify) → métricas separadas
// - Precisa cachear o responseJson (1h TTL — feature "Gerar novamente")
model AiInsightsLog {
  id               String   @id @default(cuid())
  companyId        String
  userId           String?
  // Feature que gerou a chamada (ex: 'monthly-insights')
  feature          String
  // Modelo usado (ex: 'claude-sonnet-4-6')
  model            String
  // Períodos analisados — pra cache lookup.
  // Hotfix 5.0.4.0c1-fix: campos agora aceitam YYYY-MM-DD (ISO start date).
  // Compat com YYYY-MM antigo (parser aceita os 2 formatos).
  currentPeriod    String? // ISO YYYY-MM-DD (start do período principal)
  currentEndPeriod String? // ISO YYYY-MM-DD (end do período principal)
  basePeriod       String? // ISO YYYY-MM-DD (start do período de comparação, NULL em evolution/single)
  baseEndPeriod    String? // ISO YYYY-MM-DD (end do período de comparação)
  // 'comparative' | 'evolution' | 'single' — modo inferido automaticamente
  mode             String?
  inputTokens      Int      @default(0)
  outputTokens     Int      @default(0)
  // Custo em centavos USD × 100 (mesma convenção do AiUsageLog)
  costCents        Int      @default(0)
  elapsedMs        Int      @default(0)
  // JSON com a análise gerada (cache + auditoria histórica)
  responseJson     String?
  // Se falhou, mensagem do erro
  errorMessage     String?
  createdAt        DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([companyId, feature, currentPeriod, basePeriod, createdAt])
  @@map("ai_insights_log")
}

// ============================================================
// Sprint 1.5 — Esqueci senha (código 6 dígitos via Resend)
// ============================================================
//
// Fluxo: user solicita reset → gera código random 6 dígitos → bcrypt hash
// salvo aqui → envia código em claro via email Resend → user volta com
// código → valida (max 5 tentativas) → emite JWT temporário scope=password-reset
// (15min) → user troca senha.
//
// codeHint guarda os 2 primeiros dígitos (ex: "48****") pra dica UX
// "Código começa com 48" caso user precise confirmar qual email recebeu.
model PasswordResetCode {
  id        String    @id @default(cuid())
  userId    String
  code      String // bcrypt hash do código 6 dígitos (NUNCA texto puro)
  codeHint  String? // primeiros 2 dígitos pra dica visual ("48****")
  expiresAt DateTime // now + 15 min
  usedAt    DateTime?
  attempts  Int       @default(0) // brute force guard — invalida em 5
  ipAddress String?
  userAgent String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_codes")
}

// ============================================================
// Sprint 1.6 — Painel GERENCIADOR (admin.caixaos.com.br)
// ============================================================
//
// Tabela SEPARADA do User do app. NUNCA cruza com clientes.
// Decisões registradas em docs/DECISOES.md:
//   - Por que não SUPERADMIN no User: impossibilidade de promoção acidental
//   - Por que JWT_SECRET_ADMIN diferente: vazamento em um lado não compromete outro
//   - Por que Cookie Domain=admin.caixaos.com.br literal: isolamento total
//
// Acesso: gerenciador@caixaos.com.br (seed inicial, Yussef único).
// Role interna: OPERADOR (default) | OWNER (Yussef). Sem promoção via API
// — mudança só via SQL direto (proteção extra).
model Gerenciador {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String // bcrypt rounds 12
  name         String
  role         String    @default("OPERADOR") // OPERADOR | OWNER
  active       Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  auditLogs GerenciadorAuditLog[]

  @@index([email])
  @@map("gerenciadores")
}

// Audit log dos gerenciadores. ISOLADO do audit_log das companies.
// Cobre: ADMIN_LOGIN, ADMIN_LOGOUT, ADMIN_LOGIN_FAILED, ADMIN_LOGIN_RATE_LIMITED,
// CLIENT_SUSPEND (Onda 2+), COUPON_CREATE (Sprint 1.7), etc.
// Sprint 1.7 (D11): gerenciadorId vira NULLABLE pra suportar eventos
// de SISTEMA (ex: COUPON_REDEEMED disparado pelo signup sem gerenciador).
// Eventos de gerenciador continuam preenchendo o campo normalmente.
model GerenciadorAuditLog {
  id            String   @id @default(cuid())
  gerenciadorId String? // NULL = evento de sistema (Sprint 1.7)
  action        String
  entityType    String?
  entityId      String?
  metadata      String? // JSON
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())

  gerenciador Gerenciador? @relation(fields: [gerenciadorId], references: [id], onDelete: Cascade)

  @@index([gerenciadorId, createdAt(sort: Desc)])
  @@index([action])
  @@map("gerenciador_audit_log")
}

// ============================================================
// Sprint 1.7 — Cupons (admin.caixaos.com.br/cupons)
// ============================================================
//
// 3 tipos de desconto (D12 em docs/DECISOES.md):
//   - PERCENTAGE   — value=100 significa 100% off (ex: FUNDADOR100)
//   - FIXED_AMOUNT — value em reais (ex: 50.00 = R$ 50 off)
//   - FREE_MONTHS  — usa freeMonths (ex: 3 = 3 meses grátis)
//
// Status:
//   - ACTIVE      — disponível
//   - PAUSED      — temporariamente desabilitado (gerenciador pode retomar)
//   - EXPIRED     — passou validUntil (auto via query, sem setar campo)
//   - EXHAUSTED   — atingiu maxUses
//   - DEACTIVATED — soft delete (desativado permanente)
//
// Enums implementados como String + comment (padrão do projeto, igual
// users.role, categories.type, etc).
model Coupon {
  id          String  @id @default(cuid())
  code        String  @unique // uppercase enforce no app-layer
  description String?
  // PERCENTAGE | FIXED_AMOUNT | FREE_MONTHS
  type        String
  // Pra PERCENTAGE: 0.01-100.00 · Pra FIXED_AMOUNT: valor em R$ · Pra FREE_MONTHS: irrelevante (use freeMonths)
  value       Decimal
  freeMonths  Int? // só pra type=FREE_MONTHS

  // Validade
  validFrom  DateTime  @default(now())
  validUntil DateTime?

  // Limites
  maxUses        Int? // null = ilimitado
  maxUsesPerUser Int  @default(1)
  currentUses    Int  @default(0)

  // Status (string + comment, igual demais models)
  // ACTIVE | PAUSED | EXPIRED | EXHAUSTED | DEACTIVATED
  status String @default("ACTIVE")

  // Quem criou (Gerenciador.id) — string sem FK porque é tabela ISOLADA
  // de outro contexto. Auditoria via gerenciador_audit_log.
  createdById     String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deactivatedAt   DateTime?
  deactivatedById String?

  redemptions CouponRedemption[]

  @@index([code])
  @@index([status])
  @@index([validUntil])
  @@map("coupons")
}

// 1 redemption por (user, cupom) — enforce maxUsesPerUser=1 nativamente
// via @@unique. Pra maxUsesPerUser > 1 no futuro, remover essa unique e
// validar app-layer.
model CouponRedemption {
  id         String   @id @default(cuid())
  couponId   String
  userId     String
  redeemedAt DateTime @default(now())

  // Snapshot (audit): code/type/value no momento da redemption.
  // Se cupom for editado/desativado depois, snapshot preserva contexto.
  codeSnapshot  String
  typeSnapshot  String
  valueSnapshot Decimal

  ipAddress String?
  userAgent String?

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([couponId, userId])
  @@index([userId])
  @@index([redeemedAt])
  @@map("coupon_redemptions")
}

// ============================================================
// Onda 2 Sprint 2.3 — Histórico de imports OFX
// ============================================================
//
// Cada upload de arquivo OFX cria 1 OfxImport (status PROCESSING).
// Ao final, status vira SUCCESS (com totais) ou FAILED (com errorMessage).
// "Reverter" um import deleta as transações vinculadas (importId) e marca
// status=REVERTED — o registro do import permanece pra auditoria.
//
// Multi-OFX (Sprint 2.4): cada arquivo gera 1 linha (processamento sequencial).
model OfxImport {
  id                String    @id @default(cuid())
  bankAccountId     String
  userId            String
  // PROCESSING | SUCCESS | FAILED | REVERTED
  status            String    @default("PROCESSING")
  fileName          String
  fileSize          Int       @default(0)
  totalTransactions Int       @default(0)
  newTransactions   Int       @default(0)
  duplicates        Int       @default(0)
  autoClassified    Int       @default(0)
  periodStart       DateTime?
  periodEnd         DateTime?
  ipAddress         String?
  userAgent         String?
  errorMessage      String?
  revertedAt        DateTime?
  revertedById      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  bankAccount  BankAccount   @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  revertedBy   User?         @relation("OfxImportReverter", fields: [revertedById], references: [id])
  transactions Transaction[]

  @@index([bankAccountId, createdAt])
  @@index([userId])
  @@index([status])
  @@map("ofx_imports")
}

// ============================================================
// Sprint 5.0.1 — IA Tributária Fundação
//
// CompanyTaxProfile: perfil tributário da empresa (regime + anexo + folha).
// TaxCalculation: histórico de cálculos DAS (snapshot pra auditoria).
//
// ⚠️ AVISO LEGAL: estes cálculos são ESTIMATIVAS baseadas em LC 123/2006 +
// tabelas vigentes 2026. NÃO substituem orientação contábil profissional.
// ============================================================

model CompanyTaxProfile {
  id           String  @id @default(cuid())
  companyId    String  @unique
  // Regime tributário ativo da empresa
  regime       String // SIMPLES_NACIONAL | LUCRO_PRESUMIDO | LUCRO_REAL
  // Anexo do Simples (I-V) — null se regime != SIMPLES_NACIONAL
  simplesAnexo String?

  // Receita Bruta Acumulada últimos 12 meses (snapshot — atualizada pelo
  // helper calculateRBA quando o user "Recalcular DAS")
  rba12m    Float   @default(0)
  // Folha últimos 12 meses (pra Fator R)
  folha12m  Float   @default(0)
  // Pró-labore mensal (computa dentro da folha pro Fator R)
  proLabore Float   @default(0)
  // CNAE principal (livre, validação leve)
  cnae      String?

  // Sprint 5.0.2 — Lucro Presumido + Real
  // Atividade (pra margem de presunção): COMERCIO | INDUSTRIA | SERVICOS |
  //   SERVICOS_HOSPITALARES | TRANSPORTE_CARGAS | TRANSPORTE_PASSAGEIROS |
  //   REVENDA_COMBUSTIVEIS | CONSTRUCAO_CIVIL
  atividade  String?
  // UF (2 letras) pra alíquota ICMS estadual
  estado     String?
  // Se a atividade gera ICMS (comércio/indústria geralmente sim)
  hasICMS    Boolean @default(false)
  // Se gera ISS (serviços geralmente sim)
  hasISS     Boolean @default(false)
  // Margem real declarada pelo cliente (Lucro Real) — % faturamento que vira
  // lucro tributável. Default 15% como estimativa típica até user calibrar.
  margemReal Float   @default(15)

  // Sprint 5.0.2.b — CNAE Expert vinculado
  cnaeActivityId String?

  // Toggle pro user pausar cálculos automáticos
  enabled Boolean @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  company      Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy    User?            @relation("TaxProfileCreator", fields: [createdById], references: [id])
  cnaeActivity CNAEActivity?    @relation(fields: [cnaeActivityId], references: [id])
  calculations TaxCalculation[]

  @@index([companyId])
  @@index([cnaeActivityId])
  @@map("company_tax_profiles")
}

// ============================================================
// Sprint 5.0.2.b — CNAE Expert (3 ramos verticais: Restaurantes, Academias, Comércio Roupas)
//
// CNAEActivity guarda o catálogo completo de CNAEs cobertos pelo sistema +
// um snapshot da expertise (benefícios, otimizações, particularidades, erros
// comuns) em JSON. O snapshot vive no banco pra (a) ser editável sem deploy
// futuro e (b) servir como fonte versionada (campo `versao`) para auditoria.
// ============================================================

model CNAEActivity {
  id           String  @id @default(cuid())
  code         String  @unique // "5611-2/01"
  name         String // "Restaurantes e similares"
  ramo         String // RESTAURANTE | ACADEMIA | COMERCIO_ROUPA
  anexoSimples String? // ANEXO_I | ANEXO_III | etc

  // Snapshots em JSON (versionados pelo campo `versao`). String pra compat
  // SQLite-dev / Postgres-prod (sem usar Json nativo).
  expertise        String // EXPERTISE_RAMO completo (anexoPreferido, fatorR, etc)
  beneficios       String // Array<BeneficioFiscal>
  particularidades String // Array<string>
  errosComuns      String // Array<string>

  ativo  Boolean @default(true)
  versao String  @default("2026")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  taxProfiles CompanyTaxProfile[]

  @@index([code])
  @@index([ramo])
  @@map("cnae_activities")
}

model TaxCalculation {
  id        String @id @default(cuid())
  profileId String
  companyId String

  // Período de Apuração (PA): ano + mês competência
  paYear  Int
  paMonth Int

  // Snapshot dos inputs no momento do cálculo
  regime       String
  simplesAnexo String?
  receitaBruta Float
  rbaAcumulada Float
  folha12m     Float
  fatorR       Float?

  // Outputs Simples Nacional
  aliquotaNominal Float?
  parcelaDeduzir  Float?
  aliquotaEfetiva Float?

  // Valor final DAS (R$)
  dasValue Float

  // JSON breakdown { irpj, csll, pis, cofins, cpp, icms, iss, ... } + warnings[]
  breakdown String

  // Versão da tabela usada (rastreabilidade quando tabelas mudarem)
  versaoTabela String @default("2026")

  createdAt DateTime @default(now())

  profile CompanyTaxProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  company Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Anti-dup: 1 cálculo por (profile, ano, mês). Recálculo é UPDATE.
  @@unique([profileId, paYear, paMonth])
  @@index([companyId, paYear, paMonth])
  @@map("tax_calculations")
}

// ============================================================
// Sprint 5.0.2.d — AI Analysis Cache
//
// Cache 24h de análises tributárias geradas via Claude. Hash em cima do
// snapshot relevante (CNAE + regime + receita média + folha + período).
// Quando os dados mudam, hash muda, cache é refeito. Analysis JSON
// armazenada como String (compat SQLite-dev / Postgres-prod).
// ============================================================

model AiAnalysisCache {
  id        String @id @default(cuid())
  companyId String

  // Cache key: hash sha256 de { companyId, cnae, regime, receita, folha, period }
  cacheKey String

  // Inputs
  topic       String // "general" | "regime-otimo" | "icms-st" | "fator-r" | ...
  periodStart DateTime
  periodEnd   DateTime

  // Outputs (JSON serializado)
  analysis     String // TaxAnalysisResult serializado
  modelUsed    String // "claude-sonnet-4-6"
  tokensInput  Int    @default(0)
  tokensOutput Int    @default(0)
  // Custo em USD (Float pra compat dual-DB)
  costUSD      Float  @default(0)

  // TTL — runtime descarta se Date.now() > expiresAt
  expiresAt DateTime

  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, cacheKey])
  @@index([companyId, expiresAt])
  @@map("ai_analysis_cache")
}

// ============================================================
// Sprint 5.0.2.h — Detecção automática Pix PJ↔PF e PJ↔PJ grupo.
//
// Quando Yussef cadastra:
//   - SocioPF: seu CPF, chaves Pix (email/tel/aleatorias)
//   - EmpresaRelacionada: outros CNPJs do grupo, chaves Pix delas
// Sistema detecta Pix nas Transactions e categoriza automaticamente:
//   - Pix PJ→CPF sócio  = Distribuição de Lucros / Pró-labore
//   - Pix entre CNPJs do grupo = Transferência entre Contas (filtrada do DRE)
//
// Compat dual-DB: pixKeys serializadas como String (JSON array). Postgres
// permite String[] mas SQLite-dev não. Padrão do projeto: JSON em TEXT.
// ============================================================

model SocioPF {
  id        String @id @default(cuid())
  companyId String

  nome    String
  cpf     String? // Pode ser null se user não souber/quiser
  // JSON array de chaves Pix: email, telefone, CPF, aleatória
  pixKeys String  @default("[]")
  // SOCIO | ADMINISTRADOR | FAMILIAR
  papel   String  @default("SOCIO")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  // Sprint PF Fatia 4 (03/06/2026) — Pontes que rastrearam este sócio (opcional)
  bridges PJtoPFBridge[]

  @@unique([companyId, cpf])
  @@index([companyId])
  @@map("socios_pf")
}

model EmpresaRelacionada {
  id        String @id @default(cuid())
  companyId String // empresa de referência

  cnpjRelacionado String
  nomeFantasia    String
  // JSON array de chaves Pix do CNPJ relacionado
  pixKeys         String @default("[]")
  // MESMO_GRUPO | SOCIO_COMUM | CONTROLADA | CONTROLADORA
  relacao         String @default("MESMO_GRUPO")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, cnpjRelacionado])
  @@index([companyId])
  @@map("empresas_relacionadas")
}

// Sprint 5.0.2.l — Knowledge Base setorial de padrões de categorização BR.
//
// Estrutura: padrões CURATED por setor (UNIVERSAL + RESTAURANTE + ACADEMIA + ...).
// Aplicados como Fase 3 do pipeline (entre regras aprendidas e Claude AI).
//
// Query típica:
//   prisma.setorPattern.findMany({
//     where: { active: true, setor: { in: ["UNIVERSAL", empresa.setor] } },
//     orderBy: [{ setor: "desc" }, { confidence: "desc" }],
//   })
//
// Multi-tenant: padrões são GLOBAIS (não pertencem a empresa). Cada empresa
// só lê padrões UNIVERSAL + os do seu próprio setor. Crowd-sourcing futuro
// (CROWDSOURCED_FUTURE em origem) entra aqui.
model SetorPattern {
  id String @id @default(cuid())

  // RESTAURANTE | ACADEMIA | COMERCIO_ROUPA | VAREJO_GERAL | UNIVERSAL
  setor String

  matchType String // STARTS_WITH | CONTAINS | EQUALS
  pattern   String

  // Nome canônico da categoria (resolvido contra plano de contas via
  // ensureAllSystemCategories ou resolveUniversalCategoryId).
  categoryName String
  // INCOME | EXPENSE | ANY
  type         String
  confidence   Float  @default(0.9)

  description String?
  // CURATED | CROWDSOURCED_FUTURE (next sprints)
  origem      String  @default("CURATED")

  active Boolean @default(true)

  createdAt DateTime @default(now())

  @@index([setor, active])
  @@index([pattern])
  @@map("setor_patterns")
}

// Sprint 5.0.2.n — Cache GLOBAL anonimizado de descobertas de vendor.
//
// Compartilhado entre TODAS as empresas do CAIXAOS. Network effect:
//   - 1º cliente paga lookup (BrasilAPI ou Claude AI)
//   - 2º cliente reusa direto do cache (instantâneo, grátis)
//
// PRIVACIDADE LGPD: NUNCA armazena companyId, valores, dados pessoais.
// Apenas:
//   - Identificação pública do vendor (CNPJ + razão social — dados Receita)
//   - Categoria contábil sugerida
//   - Estatísticas agregadas (aceito/rejeitado por X usuários no total)
model GlobalVendorKnowledge {
  id String @id @default(cuid())

  // CNPJ é unique quando preenchido. nome é sempre preenchido.
  cnpj                 String?
  vendorName           String
  // sem acentos, lowercase, pra busca fuzzy
  vendorNameNormalized String

  // Dados oficiais via BrasilAPI (quando disponível)
  razaoSocial   String?
  nomeFantasia  String?
  cnaePrincipal String?
  cnaeDescricao String?
  setor         String?

  // Sugestão contábil
  categoriaSugerida   String
  categoriaConfidence Float
  // INCOME | EXPENSE | ANY
  tipoTransacao       String

  // BRASIL_API | CLAUDE_AI | USER_CONFIRMED
  origem       String
  descobertoEm DateTime @default(now())

  // Estatísticas agregadas (todos clientes somados)
  vezesUsado      Int @default(0)
  vezesConfirmado Int @default(0)
  vezesRejeitado  Int @default(0)

  // Score dinâmico — ajustado por cron baseado em accept rate
  scoreAtual Float   @default(0.85)
  active     Boolean @default(true)

  ultimaValidacao DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // CNPJ é unique quando preenchido (caller faz upsert via findFirst dado o nullable)
  @@unique([cnpj])
  @@index([vendorNameNormalized])
  @@index([scoreAtual, active])
  @@map("global_vendor_knowledge")
}

// Sprint 5.0.2.n — Log de discoveries por empresa (auditoria + ajuste).
// É POR EMPRESA, mas NÃO contém dados pessoais — só metadados da chamada.
model VendorDiscoveryLog {
  id            String  @id @default(cuid())
  companyId     String
  transactionId String?

  vendorNameQueried String
  cnpjQueried       String?

  // CACHE_GLOBAL | BRASIL_API | CLAUDE_AI | NONE
  origem    String
  // FOUND | NOT_FOUND | LOW_CONFIDENCE
  resultado String

  responseTime Int
  custoApi     Float?

  // ACCEPTED | REJECTED | MODIFIED | null
  userAction      String?
  finalCategoryId String?

  // Sprint 5.0.2.o — debug fields pra diagnosticar prompts ruins
  claudeRawResponse String?
  estrategiaUsada   String? // RECONHECIMENTO_DIRETO | PISTA_NO_NOME | CONTEXTO | SEM_PISTA
  matchedKeyword    String? // se ETAPA keyword bateu, qual palavra

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([createdAt])
  @@map("vendor_discovery_logs")
}

// Sprint 5.0.2.u — Multi-statement staging (padrão Xero/QuickBooks).
//
// User importa N extratos OFX juntos. Sistema detecta transferências
// cross-account no staging ANTES de criar Transactions. User revisa e
// confirma → tx vão pra Transaction com transferGroupId correto.
//
// Idempotência: fileHash unique por empresa pra detectar reuploads.
model ImportStaging {
  id        String @id @default(cuid())
  companyId String

  // Batch — múltiplos OFX sob mesmo batchId quando enviados juntos
  batchId String

  // Origem
  bankAccountId String
  fileName      String
  fileHash      String // sha256 do conteúdo OFX

  // Snapshot estatístico
  totalTransactions Int
  totalCreditsCents Int       @default(0) // armazena em centavos pra evitar Decimal precision
  totalDebitsCents  Int       @default(0)
  periodStart       DateTime?
  periodEnd         DateTime?

  // PENDING_REVIEW | TRANSFER_DETECTED | CONFIRMED | CANCELLED
  status     String    @default("PENDING_REVIEW")
  importedAt DateTime?

  createdAt DateTime @default(now())

  // Relations
  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bankAccount        BankAccount         @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  stagedTransactions StagedTransaction[]

  @@unique([companyId, fileHash])
  @@index([companyId, batchId])
  @@index([companyId, status])
  @@map("import_stagings")
}

model StagedTransaction {
  id        String @id @default(cuid())
  stagingId String

  // Dados originais OFX
  fitId        String?
  effectedDate DateTime
  amount       Float
  // CREDIT | DEBIT
  type         String
  description  String

  // Detecção de transferência cross-account (Sprint u)
  isInternalTransfer Boolean @default(false)
  matchedStagedId    String?
  transferConfidence Float?
  transferReason     String?

  createdAt DateTime @default(now())

  staging ImportStaging @relation(fields: [stagingId], references: [id], onDelete: Cascade)

  @@index([stagingId])
  @@index([matchedStagedId])
  @@map("staged_transactions")
}

// ─────────────────────────────────────────────────────────────────────────
// Sprint 5.0.2.0 — Importador Excel de Contas a Pagar (CAIXAOS)
// ─────────────────────────────────────────────────────────────────────────

// Employee MINIMAL — separa funcionários de Suppliers (folha tem natureza
// distinta: encargos, 13º, rescisão). Plano de contas setorial (Sprint s)
// tem categorias como "Salário Professor" que ganham filtro próprio.
//
// Campos adicionais (CPF, cargo, admissão, salário base) ficam pra Sprint
// dedicada de Folha/RH. Aqui: NOME + TIPO + ATIVO.
model Employee {
  id        String  @id @default(cuid())
  companyId String
  nome      String
  // CLT | ESTAGIO | PJ | AUTONOMO (mantido como String pra evolução fácil)
  tipo      String  @default("CLT")
  ativo     Boolean @default(true)
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([companyId, nome])
  @@index([companyId, ativo])
  @@map("employees")
}

// Lote de import Excel — análogo a ImportStaging (Sprint u OFX) mas pra AP.
// Status: PENDING_REVIEW → DETECTED → CONFIRMED | CANCELLED
model ExcelImportBatch {
  id        String @id @default(cuid())
  companyId String

  // Origem
  fileName   String
  fileHash   String // sha256 do conteúdo completo (idempotência)
  // sha256 SÓ dos headers (linha 1) — usado pra cache cross-import
  // ("aprendizado": próxima planilha com mesmo header reusa column mapping)
  headerHash String

  // Snapshot stats
  totalRows         Int
  totalCreditsCents Int       @default(0)
  totalDebitsCents  Int       @default(0)
  periodStart       DateTime?
  periodEnd         DateTime?

  // PENDING_REVIEW | DETECTED | CONFIRMED | CANCELLED
  status     String    @default("PENDING_REVIEW")
  importedAt DateTime?

  // Snapshot do mapeamento de colunas decidido pela IA (JSON)
  // ex: {"favorecido":"Favorecido","valor":"Valor","vencimento":"Vencimento",...}
  columnMapping    String?
  // Confidence agregada da detecção (0-1)
  detectConfidence Float?
  // Custo Claude API em USD pra essa detecção
  detectCostUsd    Float?  @default(0)

  createdAt DateTime @default(now())

  company    Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stagedRows StagedPayableRow[]

  @@unique([companyId, fileHash])
  @@index([companyId, status])
  @@index([companyId, headerHash])
  @@map("excel_import_batches")
}

// Linha individual do staging — vira Transaction PAYABLE ao confirmar.
model StagedPayableRow {
  id      String @id @default(cuid())
  batchId String

  // Índice da linha na planilha (pra UI mostrar)
  rowIndex Int

  // ──── Dados brutos extraídos da planilha (snapshot, não muda) ────
  rawFavorecido   String?
  rawBeneficiario String?
  rawDescricao    String?
  rawCentroCusto  String?
  rawLancamento   String? // string DD/MM/YYYY
  rawCompetencia  String? // string MM/YYYY
  rawVencimento   String?
  rawPagamento    String? // vazio = a pagar
  rawValor        Float?
  rawValorBaixa   Float?
  rawNota         String?
  rawStatus       String?

  // ──── Dados normalizados pelo parser ────
  valor         Float
  vencimento    DateTime?
  pagamento     DateTime?
  competencia   DateTime?
  // PAID se pagamento preenchido; PENDING se vazio
  paymentStatus String // "PAID" | "PENDING"

  // Sprint CSV Import (30/05/2026) — pra CACULA fast-path determinar
  // lifecycle no upload. Null pro Excel/CSV genérico — confirm usa
  // lógica antiga baseada em paymentStatus. Quando preenchido,
  // confirm usa este valor (já validado por validateLifecycleState
  // pra impedir bug R$ 939k).
  lifecycle String? // "EFFECTED" | "PAYABLE" | "RECEIVABLE" | NULL

  // ──── Match decidido pela IA (sugestão pra user revisar) ────
  // Tipo de favorecido: SUPPLIER | EMPLOYEE | ORGAO_PUBLICO
  favorecidoType       String?
  // Match com Supplier/Employee existente (null = novo)
  matchedSupplierId    String?
  matchedEmployeeId    String?
  // Confidence do match favorecido (0-1)
  favorecidoConfidence Float?

  // Match com Category do plano de contas (Sprint s)
  matchedCategoryId    String?
  // Nome novo proposto se não houve match (será criado no confirm)
  proposedCategoryName String?
  // Confidence do match categoria (0-1)
  categoryConfidence   Float?

  // ──── Anti-dup ────
  // sha256(favorecido + descricao + vencimento + valor) — bate contra
  // Transaction.dedupHash dos últimos 90 dias da empresa
  dedupHash   String?
  duplicateOf String? // Transaction.id caso bata

  // ──── Decisão do user no staging ────
  // INCLUDE (default) | EXCLUDE (user marcou) | NEEDS_REVIEW (low confidence)
  userDecision String @default("INCLUDE")

  // Mensagem de validação (em PT-BR) — null se OK
  validationError String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  batch ExcelImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId, userDecision])
  @@index([batchId, paymentStatus])
  @@map("staged_payable_rows")
}

// Sprint Engine de Assinatura FATIA 1 (31/05/2026)
// Subscription do usuário. 1:1 com User. Fonte da verdade pro acesso
// ao app + trial + bloqueio EXPIRED. Campos de gateway preparados
// nullable pra Fatia 3 (Asaas) sem migração futura.
model Subscription {
  id     String @id @default(cuid())
  userId String @unique

  // Plano contratado (id de lib/planos/config.ts):
  // 'inicio' | 'controle' | 'inteligencia' | 'performance'
  planId String

  // Estado da assinatura:
  // TRIAL    — em período de teste grátis (trialEndsAt no futuro)
  // ACTIVE   — paga e em dia
  // EXPIRED  — trial acabou OU pagamento parou
  // CANCELED — user cancelou explicitamente
  // PAST_DUE — cobrança falhou (Fatia 3)
  // GRANTED  — concedida sem cobrança (early adopter / cortesia / equipe)
  status String @default("TRIAL")

  // Trial 14 dias contados do cadastro. Pode ser estendido por cupom
  // FREE_MONTHS. NULL quando não-trial (ACTIVE/GRANTED direto).
  trialEndsAt DateTime?

  // Fim do ciclo pago atual (Fatia 3 preenche). null no trial/granted.
  currentPeriodEnd DateTime?

  canceledAt DateTime?

  // Snapshot do cupom que originou desconto/trial estendido (audit).
  // Não-FK porque cupom pode ser deletado e queremos preservar trace.
  originCouponId String?

  // ===== Fatia 3 (gateway de pagamento) — preparado mas nullable =====
  gatewayCustomerId     String?
  gatewaySubscriptionId String?

  // Sprint Asaas 3B (31/05/2026) — última sessão de checkout cartão.
  // Usado pra dedup (cliques rápidos) e callback /assinar/sucesso.
  checkoutSessionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Sprint Asaas 3C (02/06/2026) — relação reversa
  webhookEvents WebhookEvent[]

  @@index([status])
  @@index([trialEndsAt])
  @@map("subscriptions")
}

// Sprint Asaas FATIA 3C (02/06/2026) — Webhook events do Asaas.
// Idempotência rígida: asaasEventId UNIQUE garante que mesmo evento
// não é processado 2x (Asaas envia at-least-once).
// Auditoria: payload completo guardado pra debug + além dos 14d Asaas.
model WebhookEvent {
  id String @id @default(cuid())

  // body.id do payload Asaas — chave de idempotência.
  // Formato: "evt_<hash>&<numero>"
  asaasEventId String @unique

  // body.event — tipo do evento (PAYMENT_CONFIRMED, PAYMENT_RECEIVED, ...).
  eventType String

  // body.payment.id — id da cobrança no Asaas. NULL em eventos
  // que não envolvem payment (raros, ex: ACCOUNT_STATUS_UPDATED).
  paymentId String?

  // FK pra Subscription quando conseguimos identificar (via
  // externalReference, gatewaySubscriptionId ou gatewayCustomerId).
  // NULL quando não localizamos (gravado com status=ERROR).
  subscriptionId String?

  // body completo do evento (JSON stringificado) — auditoria + debug.
  // 4-8KB típico (cobrança Asaas tem ~30 campos).
  // String (não Json) pra portabilidade dual SQLite-dev / Postgres-prod.
  payload String

  // Estado do processamento:
  //   RECEIVED  — gravado mas ainda não roteado (transiente)
  //   PROCESSED — efeito aplicado na Subscription
  //   IGNORED   — evento não-relevante pra nós (gravado pra auditoria)
  //   ERROR     — Subscription não localizada / erro durante processamento
  status String

  // Mensagem técnica quando status=ERROR (debug).
  errorMessage String?

  processedAt DateTime?
  createdAt   DateTime  @default(now())

  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([eventType])
  @@index([paymentId])
  @@index([status])
  @@index([createdAt])
  @@map("webhook_events")
}

// ============================================================
// Sprint PF Fatia 1 (02/06/2026) — Fundação PESSOA FÍSICA
// ============================================================
// Schema paralelo a Company/Transaction/BankAccount/Category — não
// reusa as PJ pra preservar o Princípio Contábil da Entidade (PF ≠ PJ).
// Migration 100% ADITIVA: zero ALTER em tabelas PJ existentes.

model PersonalProfile {
  id String @id @default(cuid())

  // CPF opcional (multiplos perfis por CPF possíveis em casos legítimos —
  // ex: conta conjugal). Index pra busca, sem UNIQUE.
  cpf  String?
  name String // "Yussef", "Filho Pedro", "Filha Ana"

  // OWN       — perfil do titular adulto (gerencia o próprio)
  // DEPENDENT — perfil menor de idade gerenciado pelo OWN (filho/filha)
  type String @default("OWN")

  birthDate DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  users           UserPersonalProfile[]
  bankAccounts    PersonalBankAccount[]
  transactions    PersonalTransaction[]
  categories      PersonalCategory[]
  // Sprint PF Fatia 2
  creditCards     CreditCard[]
  // Sprint PF Fatia 3
  aiLearningRules AiLearningRule[]
  ofxImports      PersonalOfxImport[]
  // Sprint PF Fatia 4 (03/06/2026) — Pontes deste perfil
  bridges         PJtoPFBridge[]

  @@index([cpf])
  @@map("personal_profiles")
}

// Vínculo User ↔ PersonalProfile (N:N — 1 user pode gerenciar vários perfis;
// 1 perfil pode ser visto por vários users via convites na Fatia 5).
model UserPersonalProfile {
  id        String @id @default(cuid())
  userId    String
  profileId String

  // OWNER — pode editar tudo (default ao criar perfil)
  // VIEWER — só lê (Fatia 5 vai introduzir via convites entre users)
  role String @default("OWNER")

  // true: o perfil é DO PRÓPRIO usuário (não dependente).
  // Útil pra "saudar pelo nome" e marcar self-profile pra ponte PJ→PF (Fatia 4).
  isSelf Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile PersonalProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([userId, profileId])
  @@index([userId])
  @@index([profileId])
  @@map("user_personal_profiles")
}

model PersonalBankAccount {
  id        String @id @default(cuid())
  profileId String

  name          String
  bankName      String?
  bankCode      String?
  agency        String?
  accountNumber String?
  // CHECKING | SAVINGS | DIGITAL_WALLET
  accountType   String  @default("CHECKING")
  balance       Float   @default(0)

  // Reuso do conceito Sprint 0.5 (cheque especial PJ).
  allowNegativeBalance Boolean @default(true)
  creditLimit          Float   @default(0)
  lowBalanceThreshold  Float?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile             PersonalProfile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  transactions        PersonalTransaction[]
  // Sprint PF Fatia 2 — cartões que usam essa conta como pagamento default
  cardDefaultPayments CreditCard[]          @relation("CardDefaultPayment")
  // Sprint PF Fatia 3
  ofxImports          PersonalOfxImport[]

  @@index([profileId])
  @@map("personal_bank_accounts")
}

model PersonalTransaction {
  id            String  @id @default(cuid())
  profileId     String // redundante via bankAccount, mas necessário pra queries diretas
  bankAccountId String?
  categoryId    String?

  date        DateTime
  description String
  amount      Float // sempre positivo; sinal vem de `type`
  // CREDIT (entrada) | DEBIT (saída)
  // TRANSFER (entre contas do mesmo perfil) fica pra fatia futura.
  type        String
  // PENDING | RECONCILED | IGNORED
  status      String   @default("RECONCILED")
  // MANUAL (Fatia 1) | OFX | AI (Fatia 3)
  origin      String   @default("MANUAL")

  externalId String?
  dedupHash  String?

  notes String?

  // === Sprint PF Fatia 2 (02/06/2026) — Cartão de crédito ===
  // Quando preenchidos, esta tx é compra/pagamento de cartão.
  // NULL = tx normal (Fatia 1 — entrada/saída direta em conta bancária).
  creditCardId        String?
  creditCardInvoiceId String?

  // Parcelamento Nx: compra cria N tx com o MESMO installmentGroupId.
  installmentNumber  Int?
  installmentTotal   Int?
  installmentGroupId String?

  // True quando esta tx é o PAGAMENTO da fatura (debita conta bancária).
  // False (default) = compra ou crédito normal.
  isInvoicePayment Boolean @default(false)

  // === Sprint PF Fatia 3 (03/06/2026) — Import OFX + IA categorização PF ===
  // FK pra PersonalOfxImport quando tx veio de OFX/PDF.
  ofxImportId           String?
  // Compra internacional detectada (regex "internacional" no memo).
  isInternational       Boolean @default(false)
  internationalCurrency String?
  // Qual AiLearningRule classificou (NULL = manual ou IA Claude direta).
  classifiedByRuleId    String?
  // Confidence da categorização IA (0-1; NULL pra MANUAL).
  aiConfidence          Float?
  // RULE | KEYWORD | CLAUDE | MANUAL — origem da categoria
  classifiedBy          String?

  // === Sprint PF Fatia 4 (03/06/2026) — Ponte PJ→PF ===
  // Decisão: lookup via UNIQUE em PJtoPFBridge.pfTransactionId (sem ADD COLUMN aqui).
  // Relação inverse abaixo.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile           PersonalProfile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  bankAccount       PersonalBankAccount? @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)
  category          PersonalCategory?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  creditCard        CreditCard?          @relation(fields: [creditCardId], references: [id], onDelete: SetNull)
  creditCardInvoice CreditCardInvoice?   @relation(fields: [creditCardInvoiceId], references: [id], onDelete: SetNull)
  // Sprint PF Fatia 3
  ofxImport         PersonalOfxImport?   @relation(fields: [ofxImportId], references: [id], onDelete: SetNull)
  classifiedByRule  AiLearningRule?      @relation("PfClassifiedByRule", fields: [classifiedByRuleId], references: [id], onDelete: SetNull)
  // Sprint PF Fatia 4 — ponte (1:0..1). Restrict no delete.
  bridge            PJtoPFBridge?        @relation("PfBridge")

  @@index([profileId, date])
  @@index([bankAccountId])
  @@index([categoryId])
  @@index([creditCardId])
  @@index([creditCardInvoiceId])
  @@index([installmentGroupId])
  @@index([ofxImportId])
  @@map("personal_transactions")
}

model PersonalCategory {
  id        String  @id @default(cuid())
  profileId String? // NULL = template default (não vinculado a perfil)

  name String
  // INCOME (receita) | EXPENSE (despesa)
  type String

  color     String?
  icon      String?
  isDefault Boolean @default(false)

  // Hierarquia opcional (Mercado/Restaurante dentro de Alimentação, etc).
  parentId String?
  parent   PersonalCategory?  @relation("PersonalCategoryParent", fields: [parentId], references: [id], onDelete: SetNull)
  children PersonalCategory[] @relation("PersonalCategoryParent")

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile         PersonalProfile?      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  transactions    PersonalTransaction[]
  // Sprint PF Fatia 3
  aiLearningRules AiLearningRule[]

  @@index([profileId])
  @@index([parentId])
  @@map("personal_categories")
}

// ============================================================
// Sprint PF FATIA 2 (02/06/2026) — Cartão de crédito robusto
// ============================================================
// Schema aditivo paralelo a PersonalBankAccount/PersonalTransaction.
// Cartão NÃO é BankAccount: tem dívida + limite (não saldo), fatura
// como entidade intermediária, parcelamento Nx nativo, fechamento ≠
// vencimento. Pegadinhas resolvidas em lib/credit-card/*.

model CreditCard {
  id        String @id @default(cuid())
  profileId String // Fatia 2 só PF. PJ futuro se necessário.

  name       String // "Nubank Roxinho", "Itaú Personnalité"
  bankName   String?
  lastDigits String? // últimos 4 (auditoria; NUNCA o número completo)
  // VISA | MASTERCARD | ELO | AMEX | HIPERCARD (opcional)
  brand      String?

  creditLimit Float // limite total
  closingDay  Int // 1-31
  dueDay      Int // 1-31

  // ATUAL  — compra NO dia do fechamento entra na fatura que fecha hoje (default Nubank/Itaú)
  // PROXIMA — entra na próxima fatura (alguns bancos invertem)
  closingDayRule String @default("ATUAL")

  // Conta padrão que paga a fatura (PersonalBankAccount.id).
  // null = user escolhe a cada pagamento.
  defaultPaymentAccountId String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile               PersonalProfile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  defaultPaymentAccount PersonalBankAccount?  @relation("CardDefaultPayment", fields: [defaultPaymentAccountId], references: [id], onDelete: SetNull)
  invoices              CreditCardInvoice[]
  transactions          PersonalTransaction[]
  // Sprint PF Fatia 3
  ofxImports            PersonalOfxImport[]

  @@index([profileId])
  @@map("credit_cards")
}

model CreditCardInvoice {
  id           String @id @default(cuid())
  creditCardId String

  // Mês de competência YYYY-MM (mês do fechamento).
  // UNIQUE por cartão — 1 fatura por mês por cartão.
  reference String

  closingDate DateTime
  dueDate     DateTime

  totalAmount Float @default(0) // soma das tx vinculadas
  paidAmount  Float @default(0)

  // OPEN     — date <= closingDate (aceita lançamentos)
  // CLOSED   — closingDate < now <= dueDate (aguarda pagamento)
  // PAID     — paga total
  // PARTIAL  — paga parcial (rotativo gerou tx na próxima)
  // OVERDUE  — vencida sem pagar total
  status String @default("OPEN")

  // Rastreabilidade do rotativo: se essa fatura foi gerada por
  // carry-over de uma anterior parcial, aponta pra ela. Normal = null.
  carryoverFromInvoiceId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creditCard    CreditCard            @relation(fields: [creditCardId], references: [id], onDelete: Cascade)
  carryoverFrom CreditCardInvoice?    @relation("CarryoverChain", fields: [carryoverFromInvoiceId], references: [id], onDelete: SetNull)
  carryoverTo   CreditCardInvoice[]   @relation("CarryoverChain")
  transactions  PersonalTransaction[]

  @@unique([creditCardId, reference])
  @@index([creditCardId, status])
  @@index([dueDate])
  @@map("credit_card_invoices")
}

// ============================================================
// Sprint PF FATIA 3 (03/06/2026) — Import OFX cartão + IA PF
// ============================================================
// Histórico/auditoria de imports OFX em perfis PF. Paralelo ao
// OfxImport PJ (Sprint 2.4). Permite revert + audit + métricas.
model PersonalOfxImport {
  id            String  @id @default(cuid())
  profileId     String
  // Cartão escolhido pra import (Fatia 3 — só cartão).
  creditCardId  String?
  // bankAccountId reservado pra Fatia 3B (OFX de conta PF).
  bankAccountId String?
  userId        String

  // PROCESSING | SUCCESS | FAILED | REVERTED
  status        String @default("PROCESSING")
  fileName      String
  fileSize      Int    @default(0)
  // BANK | CREDITCARD (detectado do parser estendido)
  statementType String

  // Métricas pós-confirm
  totalTransactions      Int @default(0)
  newTransactions        Int @default(0)
  duplicates             Int @default(0)
  autoClassified         Int @default(0)
  invoicePaymentsSkipped Int @default(0)
  parcelasDetected       Int @default(0)

  periodStart DateTime?
  periodEnd   DateTime?

  // Metadados do cartão detectado (auditoria)
  detectedOrg    String? // "NU PAGAMENTOS S.A."
  detectedFid    String? // "260"
  detectedAcctId String? // ACCTID do OFX

  // === Sprint PF Fatia 3.5 (03/06/2026) — PDF via Claude Vision ===
  // OFX (default) | PDF (Fatia 3.5)
  sourceType           String  @default("OFX")
  // 0-1 — confidence global da extração (só preenchido pra PDF)
  extractionConfidence Float?
  // SHA256 do PDF (pra ligar ao cache PersonalPdfExtractCache)
  pdfSha256            String?
  // DIGITAL | SCANNED_HIGH | SCANNED_LOW | MOBILE_PHOTO (só PDF)
  pdfScanQuality       String?

  ipAddress    String?
  userAgent    String?
  errorMessage String?
  revertedAt   DateTime?
  revertedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile      PersonalProfile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  creditCard   CreditCard?           @relation(fields: [creditCardId], references: [id], onDelete: SetNull)
  bankAccount  PersonalBankAccount?  @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  revertedBy   User?                 @relation("PersonalOfxImportReverter", fields: [revertedById], references: [id])
  transactions PersonalTransaction[]

  @@index([profileId])
  @@index([creditCardId])
  @@index([status])
  @@map("personal_ofx_imports")
}

// ============================================================
// Sprint PF FATIA 3.5 (03/06/2026) — Cache de extração PDF (Vision)
// ============================================================
// Cache global por SHA256 do PDF — qualquer user que upload o MESMO
// PDF reusa a extração (sem nova chamada ao Claude Vision).
// TTL 7 dias. User pode deletar o cache do PDF dele.
//
// ⚠️ NÃO armazena o PDF em si — apenas o resultJson extraído + hash.
// ⚠️ Privacy: cartão mascarado (****1234) antes do resultJson cache.
model PersonalPdfExtractCache {
  id               String   @id @default(cuid())
  // SHA256 do PDF (lower hex 64 chars) — chave global
  pdfSha256        String   @unique
  // Modelo Claude usado (claude-sonnet-4-6 etc) — pra auditoria
  modelVersion     String
  // JSON serializado do PdfExtractResult — SEM PDF original
  resultJson       String
  // Telemetria de custo
  inputTokens      Int
  outputTokens     Int
  costCentsUsdX100 Int
  // user que primeiro fez upload — permite DELETE pra dono
  ownerUserId      String?
  // contadores
  hitCount         Int      @default(0)
  cachedAt         DateTime @default(now())
  // cachedAt + 7 dias (limpeza por job futuro)
  expiresAt        DateTime

  owner User? @relation("PdfCacheOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  @@index([pdfSha256])
  @@index([expiresAt])
  @@index([ownerUserId])
  @@map("personal_pdf_extract_cache")
}

// ============================================================
// Sprint PF Fatia 4 — Ponte PJ→PF (03/06/2026)
// ============================================================
// Conecta uma transação PJ de saída (DEBIT em transactions) com uma
// transação PF de entrada (CREDIT em personal_transactions). Preserva
// o Princípio da Entidade: cada lado fica na sua tabela; PJtoPFBridge
// só liga + classifica + rastreia.
//
// PRIVACIDADE MULTI-SÓCIO (decisões A-E no docs/sprints/pf-fatia-4-ponte.md §0.b):
// - Listagens filtram por profileId IN owned_by_user.
// - GET detalhe é 404 pra quem não é dono nem criador.
// - Sugestões filtram por userId (find-candidate-profile).
// - Badge anônimo na tx PJ pra terceiros.
//
// Migration é PURAMENTE ADITIVA: apenas CREATE TABLE pj_to_pf_bridges.
// Zero ALTER em transactions (PJ, 2907 linhas reais) e zero ALTER em
// personal_transactions (vazia mas mesma regra). Lookup "essa tx tem
// bridge?" via UNIQUE em pjTransactionId/pfTransactionId.

model PJtoPFBridge {
  id String @id @default(cuid())

  // === LADO PJ (empresa) ===
  // Sempre type=DEBIT (saída) na tx PJ. UNIQUE: cada tx PJ participa de no
  // máximo UMA ponte.
  pjTransactionId String @unique
  // Redundante mas necessário pra queries multi-tenant rápidas.
  companyId       String

  // === LADO PF (perfil pessoal) ===
  // Sempre type=CREDIT (entrada) na PersonalTransaction. UNIQUE.
  pfTransactionId String @unique
  // Redundante por simetria. Permite filtro "todas pontes do perfil X".
  profileId       String

  // === CLASSIFICAÇÃO ===
  // PRO_LABORE | DISTRIBUICAO | REEMBOLSO | ADIANTAMENTO | RETIRADA_SOCIOS
  kind String

  // Valor + data redundantes (= tx PJ / PF). Facilita relatório "pontes do mês".
  amount Float
  date   DateTime

  // === RASTREABILIDADE OPCIONAL ===
  // Quando ponte foi criada via detecção Pix PJ→CPF (5.0.2.h), aponta
  // pro SocioPF que disparou. NULL quando criação manual.
  socioPFId String?

  // === AUDITORIA ===
  createdById String
  // CREATED_FROM_DETECTION | CREATED_MANUAL
  createdVia  String @default("CREATED_MANUAL")

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // === RELATIONS ===
  // Restrict nas 2 tx → bloqueia delete direto da tx; força user deletar
  // a ponte primeiro (UX explica em 409 HAS_ACTIVE_BRIDGE).
  pjTransaction Transaction         @relation("PjBridge", fields: [pjTransactionId], references: [id], onDelete: Restrict)
  pfTransaction PersonalTransaction @relation("PfBridge", fields: [pfTransactionId], references: [id], onDelete: Restrict)
  company       Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  profile       PersonalProfile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  socioPF       SocioPF?            @relation(fields: [socioPFId], references: [id], onDelete: SetNull)
  createdBy     User                @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([companyId, date])
  @@index([profileId, date])
  @@index([socioPFId])
  @@index([createdById])
  @@map("pj_to_pf_bridges")
}
